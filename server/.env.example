# pipecat-quickstart - Environment Variables
# Copy this file to .env and fill in your API keys

# Cartesia (STT/TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=


# Anthropic (Claude LLMs)
ANTHROPIC_API_KEY=

# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL=

# Google Gemini (LLM)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Gemini Live (S2S) pre-flight probe before each call surfaces connect
# rejections in the UI, but costs one extra Live session against the (scarce)
# free-tier quota. Set to 0 to skip it.
# GEMINI_LIVE_PREFLIGHT=1

# LLM Provider selection: google, sarvam, openai
LLM_PROVIDER=

# Sarvam AI (STT/TTS)
SARVAM_API_KEY=

# Groq (LLM/STT/TTS)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Azure OpenAI (hosted LLMs) — fill both to enable the "Hosted on Azure" models
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-09-01-preview

# GCP Vertex AI (hosted LLMs) — service-account JSON path + project to enable
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_VERTEX_PROJECT_ID=
# GOOGLE_VERTEX_LOCATION=us-east4

# Playground: USD -> INR fallback rate for the cost display.
# The live rate is fetched from frankfurter.app (ECB) and cached for 6h;
# this value is only used when that fetch fails (e.g. offline).
USD_INR_RATE=88.0

